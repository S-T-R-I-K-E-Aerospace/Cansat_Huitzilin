# ============================================
# .gitignore - Cansat Huitzilin
# ============================================

# =====================
# Estacion Terrena GUI (Python / Flet / PySide6)
# =====================
# Cache y compilados de Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyo
*.pyd
*.c
*.egg
*.egg-info/
.pytest_cache/

# Entornos virtuales (Ignorar todas las dependencias)
cansat_env/
venv/
.venv/
env/
.env/
ENV/

# Archivos de empaquetado (Build/PyInstaller)
dist/
build/
*.manifest
*.spec
pip-log.txt
pip-delete-this-directory.txt

# Ejecutables compilados de la GUI (exceptuando assets)
*.exe
!Code/Estacion_Terrena/interfaz/assets/*.exe

# Salida del instalador (Inno Setup / NSIS)
installer_output/

# Datos de ejecución (runtime) de la aplicación
received_images/
recived_files/
*.log

# =====================
# Archivos de Fabricación y Diseño (MANTENER)
# =====================
# KiCad archivos temporales y copias de seguridad
*.bak
*.bck
*.tmp
*.kicad_prl
*.kicad_sch-bak
*.kicad_pcb-bak
*.kicad_wks
*.000
*.gbrjob
*~
_autosave-*
*-backups/
fp-info-cache
sym-lib-table-bak
*-cache.lib
*-cache.kicad_sym
*-rescue.kicad_sch

# Archivos generados de fabricación KiCad que NO deben estar en repo si solo quieres las fuentes
*.pos
*.gbr
*.gtp
*.gts
*.gto
*.gm*
*.drl

# Autodesk Inventor / CAD (Ignorar temporales)
OldVersions/
*.ipt.bak
*.iam.bak
*.idw.bak
*.ipn.bak
Design\ Cache/

# Configuración y tablas locales (Opcional ignorar)
*.ini
*.cfg
fp-lib-table
sym-lib-table

# =====================
# Documentos y Empaquetados
# =====================
*.pdf
*.zip
*.rar
*.7z
*.tar.gz

# Archivos 3D pesados de exportación (opcional si no quieres trackearlos)
# *.step
# *.stp

# =====================
# Archivos del sistema operativo
# =====================
.DS_Store
Thumbs.db
ehthumbs.db
desktop.ini
$RECYCLE.BIN/
*.lnk

# =====================
# IDEs / Editores de texto
# =====================
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace
.project
.classpath
.settings/

# =====================
# Gemini / AI assistant
# =====================
.gemini/
.agents/
