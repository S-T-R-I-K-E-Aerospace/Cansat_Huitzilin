# ============================================
# .gitignore - Cansat Huitzilin
# ============================================

# =====================
# Python
# =====================
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyo
*.pyd
*.egg
*.egg-info/
dist/
build/
*.manifest
*.spec
pip-log.txt
pip-delete-this-directory.txt

# Entornos virtuales
cansat_env/
venv/
.venv/
env/
.env/
ENV/

# PyInstaller
*.exe
!Code/Estacion_Terrena/interfaz/assets/*.exe

# Installer output
installer_output/

# =====================
# KiCad
# =====================
*.bak
*.bck
*.tmp
*.kicad_prl
*.kicad_sch-bak
*.kicad_pcb-bak
*.000
*.gbrjob
*~
_autosave-*
*-backups/
fp-info-cache
sym-lib-table-bak
*-cache.lib
*-cache.kicad_sym
*-rescue.kicad_sch

# Archivos generados de fabricación KiCad
*.pos
*.gbr
*.gtp
*.gts
*.gto
*.gm*
*.drl

# =====================
# Autodesk Inventor / CAD
# =====================
OldVersions/
*.ipt.bak
*.iam.bak
*.idw.bak
*.ipn.bak
Design\ Cache/



# =====================
# Documentos generados
# =====================
*.pdf

# =====================
# Archivos de configuración local
# =====================
*.ini
*.cfg
*.kicad_wks

# Tablas de librerías locales KiCad
fp-lib-table
sym-lib-table

# =====================
# Archivos del sistema operativo
# =====================
.DS_Store
Thumbs.db
ehthumbs.db
desktop.ini
$RECYCLE.BIN/
*.lnk

# =====================
# IDE / Editor
# =====================
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace
.project
.classpath
.settings/

# =====================
# Datos de ejecución (runtime)
# =====================
received_images/
recived_files/

# =====================
# Gemini / AI assistant
# =====================
.gemini/
.agents/
